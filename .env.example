DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/insightflow
SECRET_KEY=replace-with-a-long-random-production-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:4200
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
AI_PROVIDER=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=3
REDIS_URL=redis://redis:6379/0
NLP_ENABLE_TRANSFORMERS=true
NLP_ALLOW_MODEL_DOWNLOAD=false
NLP_TRANSFORMER_MODEL=distilbert-base-uncased
NLP_MODEL_CACHE_DIR=model-cache
NLP_MAX_CHUNKS=80
NLP_CHUNK_SIZE=900
NLP_CHUNK_OVERLAP=120
NLP_EMBEDDING_BATCH_SIZE=8
